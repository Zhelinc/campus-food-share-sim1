generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id
  email       String   @unique
  password    String?  // 哈希密码
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  role        String   @default("user")
  emailVerified Boolean @default(false)

  // 关系字段（大写，单数）
  Claim       Claim[]
  Food        Food[]
  Notification Notification[]
}

model Food {
  id          String   @id
  title       String
  description String
  allergens   String[]
  campus      String   @default("London")
  location    String
  weight        String?   // 食物重量，例如 "500g"
  expiryDays    Int?      // 保质期（天数）
  expiresAt     DateTime? // 自动计算的过期时间
  imageUrl    String?
  status      String   @default("AVAILABLE")
  publisherId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  category    String?
  Claim       Claim?          // 一对一认领
  User        User            @relation(fields: [publisherId], references: [id])
}

model Claim {
  id         String   @id @default(cuid())
  foodId     String   @unique           // 唯一约束（只保留此处）
  claimantId String
  status     ClaimStatus @default(PENDING)
  pickupTime  DateTime?
  counterPickupTime DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Claimant   User    @relation(fields: [claimantId], references: [id])
  Food       Food    @relation(fields: [foodId], references: [id])
  // 反向关系：一个认领可以有多条通知
  Notification Notification[]
}

enum ClaimStatus {
  PENDING
  ACCEPTED
  COUNTERED
  REJECTED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  claimId   String?
  type      String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关系字段
  user    User    @relation(fields: [userId], references: [id])
  Claim   Claim?  @relation(fields: [claimId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("password_resets")
}